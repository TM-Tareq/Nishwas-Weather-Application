# OpenWeatherMap API key — get from https://openweathermap.org/api
VITE_OWM_API_KEY=your_owm_api_key_here

# Backend API URL — use localhost for dev, Railway URL for production
VITE_API_URL=http://localhost:8080/api

# Cloudinary — get from https://cloudinary.com
# 1. Create a free account
# 2. Dashboard → Settings → Upload → Add upload preset (unsigned mode)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=nishwas-unsigned
